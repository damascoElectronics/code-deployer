          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT \n  DATE_FORMAT(created_at, '%Y-%m-%d %H:00:00') as time,\n  COUNT(*) as 'Total Keys'\nFROM key_creations\nWHERE created_at >= NOW() - INTERVAL 7 DAY\nGROUP BY DATE_FORMAT(created_at, '%Y-%m-%d %H:00:00')\nORDER BY time",
