    {
      "id": 8,
      "title": "Keys Generated by Source Site (102 vs 103)",
      "type": "piechart",
      "datasource": {
        "type": "mysql",
        "uid": "PBE6F30E16AE37FD9"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "PBE6F30E16AE37FD9"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  CONCAT('Site ', source_site_id) as metric,\n  COUNT(*) as value\nFROM key_creations\nWHERE source_site_id IN (102, 103)\nGROUP BY source_site_id\nORDER BY source_site_id",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
